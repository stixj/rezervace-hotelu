# Copy to .env and adjust. For local SQLite, leave DATABASE_URL unset.

# DATABASE_URL=postgresql://user:password@localhost:5432/hotel_requests

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

RECEPTION_EMAIL=reception@example.com

LOG_LEVEL=INFO

HOST=127.0.0.1
# 8010 avoids clashes with stray services on 8003 (common on dev machines).
PORT=8010
# Single process by default; set true for auto-reload while editing code.
UVICORN_RELOAD=false

CORS_ORIGINS=*

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=72

# Local dev: create users on startup if missing (disable in production or remove after first run)
BOOTSTRAP_EMPLOYEE_EMAIL=zamestnanec@local.test
BOOTSTRAP_EMPLOYEE_PASSWORD=DevZamestnanec123
BOOTSTRAP_RECEPTION_EMAIL=recepce@local.test
BOOTSTRAP_RECEPTION_PASSWORD=DevRecepce123
